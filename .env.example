# Fabric Ontology Lab Configuration
# Copy this file to .env and fill in your values
#
# NOTE: If you used 'azd up' to deploy, Azure service endpoints are loaded
# automatically from .azure/<env>/.env - no need to configure them here!

# --- Microsoft Fabric (required) ---
FABRIC_WORKSPACE_ID=your-workspace-id-here

# Solution name prefix (optional - defaults to AZURE_ENV_NAME from azd)
# SOLUTION_NAME=myproject

# --- Data Folder (pre-populated with default scenario) ---
DATA_FOLDER=data/default

# --- AI Data Generation (for customization - Step 2) ---
# First run: you can leave these defaults as-is.
# Only change them when you intentionally want to generate a new scenario.
# If INDUSTRY / USECASE are omitted and you run step 01, the script will ask interactively.
# If DATA_SIZE is omitted, it defaults to `small`.
INDUSTRY=Telecommunications
USECASE=Network operations with outage tracking and trouble ticket management
DATA_SIZE=small

# --- Foundry Tracing (optional) ---
# Set to true to send OpenTelemetry traces to Application Insights.
# Connection string is auto-resolved from the Foundry project if not set.
ENABLE_FOUNDRY_TRACING=true
# ENABLE_FOUNDRY_CONTENT_TRACING=true
# ENABLE_TRACE_CONTEXT_PROPAGATION=true
# APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- Agent IDs (auto-populated by scripts) ---
FABRIC_AGENT_ID=
FOUNDRY_AGENT_ID=

# --- Optional dedicated image generation endpoint ---
# `azd up` now attempts the optional image model as a best-effort post-provision step.
# If the region or quota cannot accept the deployment, `azd up` still completes and the
# image deployment variables are cleared from .azure/<env>/.env.
# Only override them here if you intentionally want to point to another image resource.
# AZURE_IMAGE_OPENAI_ENDPOINT=https://your-image-resource.openai.azure.com/
# AZURE_IMAGE_MODEL_DEPLOYMENT=gpt-image-1-5
# AZURE_IMAGE_OPENAI_API_KEY=only-if-your-resource-allows-local-auth

# --- Optional Browser Automation handoff ---
# `azd up` now deploys a Playwright Workspace and exposes its endpoint via azd env outputs.
# Browser Automation still needs one manual post-deploy step:
# 1. Generate a Playwright access token in Azure Portal
# 2. Create the Browser Automation connection in the Foundry project
# AZURE_PLAYWRIGHT_WS_ENDPOINT=wss://your-playwright-workspace.playwright.microsoft.com
# AZURE_PLAYWRIGHT_ACCESS_TOKEN=portal-generated-once
# AZURE_PLAYWRIGHT_CONNECTION_ID=/subscriptions/.../resourceGroups/.../providers/Microsoft.CognitiveServices/accounts/.../projects/.../connections/...

# =============================================================================
# AZURE SERVICES - Only needed if NOT using 'azd up'
# If you ran 'azd up', these are loaded from .azure/<env>/.env automatically
# =============================================================================

# --- Azure AI Foundry (from azd or manual) ---
# AZURE_AI_PROJECT_ENDPOINT=https://your-ai-service.services.ai.azure.com/api/projects/your-project
# AZURE_AI_ENDPOINT=https://your-ai-service.services.ai.azure.com
# AZURE_CHAT_MODEL=gpt-4o-mini
# AZURE_EMBEDDING_MODEL=text-embedding-3-large

# --- Azure AI Search (from azd or manual) ---
# AZURE_AI_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
