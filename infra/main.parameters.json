{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "AZURE_LOCATION": {
      "value": "${AZURE_LOCATION}"
    },
    "deploymentType": {
      "value": "${AZURE_OPENAI_MODEL_DEPLOYMENT_TYPE}"
    },
    "gptModelName": {
      "value": "${AZURE_OPENAI_DEPLOYMENT_MODEL}"
    },
    "gptModelVersion": {
      "value": "${AZURE_ENV_MODEL_VERSION}"
    },
    "gptDeploymentCapacity": {
      "value": "${AZURE_OPENAI_DEPLOYMENT_MODEL_CAPACITY}"
    },
    "embeddingModel": {
      "value": "${AZURE_OPENAI_EMBEDDING_MODEL}"
    },
    "embeddingDeploymentCapacity": {
      "value": "${AZURE_OPENAI_EMBEDDING_MODEL_CAPACITY}"
    },
    "optionalModelDeployments": {
      "value": [
        {
          "name": "gpt-4.1-mini",
          "modelName": "gpt-4.1-mini",
          "modelFormat": "OpenAI",
          "skuName": "GlobalStandard",
          "capacity": 3,
          "enabled": true,
          "modelVersion": "2025-04-14"
        },
        {
          "name": "text-embedding-3-large",
          "modelName": "text-embedding-3-large",
          "modelFormat": "OpenAI",
          "skuName": "Standard",
          "capacity": 3,
          "enabled": true,
          "modelVersion": "1"
        }
      ]
    },
    "deployDedicatedImageOpenAI": {
      "value": true
    },
    "imageOpenAILocation": {
      "value": "westus3"
    },
    "imageOpenAIDeploymentName": {
      "value": "gpt-image-1-5"
    },
    "imageOpenAIModelName": {
      "value": "gpt-image-1.5"
    },
    "imageOpenAIModelVersion": {
      "value": "2025-12-16"
    },
    "imageOpenAIDeploymentSkuName": {
      "value": "GlobalStandard"
    },
    "imageOpenAIDeploymentCapacity": {
      "value": 1
    },
    "deployBrowserAutomation": {
      "value": true
    },
    "browserAutomationLocation": {
      "value": "eastus"
    },
    "aiDeploymentsLocation": {
      "value": "${AZURE_ENV_AI_DEPLOYMENTS_LOCATION}"
    }
  }
}